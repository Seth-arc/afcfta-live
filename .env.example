# AfCFTA Intelligence API example environment.
# Copy this file to .env for local development.
# Do not commit real secrets. Replace placeholder values outside this file.

# =========================
# Application / Deployment
# Required in production: ENV
# Optional in local development: APP_TITLE, APP_VERSION
# =========================
ENV=development
APP_TITLE=AfCFTA Intelligence API
APP_VERSION=0.1.0

# =========================
# Database
# Required in all environments: DATABASE_URL
# Recommended for local tooling and migrations: DATABASE_URL_SYNC
# These values must be generated outside this repository and must never be committed
# to git. If .env.prod is currently tracked by git, run:
#   git rm --cached .env.prod
#   git commit -m 'chore: stop tracking .env.prod'
# then rotate both DATABASE_URL credentials and API_AUTH_KEY immediately.
# Timeout defaults below are development-safe and can be tightened in staging/production.
# If the database password contains reserved URL characters such as %, @, :, /, or ;,
# keep POSTGRES_PASSWORD as the raw value but URL-encode that password inside
# DATABASE_URL and DATABASE_URL_SYNC.
# The production compose file reads container runtime variables directly from
# ./.env.prod so host-shell DATABASE_URL values do not override the container DSN.
# If you copy this file to .env.prod for docker-compose.prod.yml, the API container
# can use a compose service hostname such as db.
# If you run the image directly with docker run, DATABASE_URL must point to a
# database address reachable from that standalone container; a compose-only
# hostname such as db will not resolve automatically.
# =========================
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://afcfta:change-me@localhost:5432/afcfta
DATABASE_URL_SYNC=postgresql://afcfta:change-me@localhost:5432/afcfta
DB_CONNECT_TIMEOUT_SECONDS=10
DB_COMMAND_TIMEOUT_SECONDS=15
DB_POOL_TIMEOUT_SECONDS=30
DB_STATEMENT_TIMEOUT_MS=15000
DB_LOCK_TIMEOUT_MS=5000
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# =========================
# API Authentication
# Required in all environments: API_AUTH_KEY
# API_AUTH_PRINCIPAL and API_AUTH_HEADER_NAME are optional overrides.
# These values must be generated outside this repository and must never be committed
# to git. If .env.prod is currently tracked by git, run:
#   git rm --cached .env.prod
#   git commit -m 'chore: stop tracking .env.prod'
# then rotate both DATABASE_URL credentials and API_AUTH_KEY immediately.
# Use a long random value outside the repository.
# =========================
API_AUTH_KEY=replace-with-a-long-random-secret
API_AUTH_PRINCIPAL=configured-api-client
API_AUTH_HEADER_NAME=X-API-Key

# =========================
# In-process cache for static reference lookups
# Default: true. Caches HS hierarchy, PSR rules, and tariff schedules, reducing DB
# round-trips on repeated assessments and NIM conversational retries.
# TTL default: 5 minutes (CACHE_TTL_SECONDS=300).
# Invalidate after any parser promotion or tariff-schedule update by either:
# 1. Performing a rolling worker restart for zero-downtime immediate eviction.
# 2. Setting CACHE_STATIC_LOOKUPS=false and restarting workers if the promotion
#    window requires strict immediate consistency with no stale-read window.
# CACHE_STATUS_LOOKUPS remains false by default because status assertions are
# time-windowed and operator-mutable. Enable it only for frozen gate/perf runs
# where status_assertion and transition_clause data is intentionally static.
# =========================
CACHE_STATIC_LOOKUPS=true
CACHE_STATUS_LOOKUPS=false
# CACHE_STATIC_LOOKUPS=false  # valid local / promotion-window override
CACHE_TTL_SECONDS=300

# =========================
# Rate Limiting
# Production default: true.
# Must be true in all non-local environments. Setting this to false disables all rate limiting globally.
# Local development may override this only when explicitly needed.
# =========================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX_REQUESTS=120
RATE_LIMIT_ASSESSMENTS_MAX_REQUESTS=10

# =========================
# Redis (optional — required for multi-worker rate limiting)
# When REDIS_URL is set, the API uses a Redis-backed sliding-window rate
# limiter that is safe across multiple Uvicorn worker processes.
# When unset, the API falls back to InMemoryRateLimiter, which is only
# safe for UVICORN_WORKERS=1 (state is not shared between processes).
# =========================
REDIS_URL=

# =========================
# Uvicorn worker count
# CONSTRAINT: Keep UVICORN_WORKERS=1 until REDIS_URL is configured.
# InMemoryRateLimiter state is per-process; multiple workers will each
# maintain independent buckets, making the effective rate limit
# UVICORN_WORKERS × the configured max. Once REDIS_URL points to a live
# Redis instance the rate limiter switches to a shared sliding-window
# implementation and UVICORN_WORKERS can safely be raised.
# =========================
UVICORN_WORKERS=1

# =========================
# Logging
# Optional. JSON logging is the default for machine-readable output.
# LOG_LEVEL=DEBUG is development-only and should not be copied into production unchanged.
# =========================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REQUESTS_ENABLED=true
LOG_DISABLE_UVICORN_ACCESS_LOG=true

# =========================
# Prometheus metrics scraping
# Set METRICS_ENABLED=true only when a Prometheus-compatible scraper is configured.
# In non-development environments, keep METRICS_AUTH_REQUIRED=true so /metrics is
# never public. When METRICS_AUTH_KEY is left empty, the route falls back to
# API_AUTH_KEY for authentication.
# =========================
METRICS_ENABLED=false
METRICS_AUTH_REQUIRED=true
METRICS_AUTH_HEADER_NAME=X-Metrics-Key
METRICS_AUTH_KEY=

# =========================
# Optional External Error Tracking
# Optional in all environments. Leave disabled unless the deployment has Sentry available.
#
# Activation steps:
#   1. Install the Sentry SDK:  pip install -e ".[sentry]"
#      (or add "sentry" to the extras list in the Dockerfile pip install command)
#   2. Set ERROR_TRACKING_BACKEND=sentry and SENTRY_DSN=<your-project-dsn>
#   3. Restart the API; the startup log will confirm:
#        "External error tracking initialized with backend sentry"
#   4. Set SENTRY_TRACES_SAMPLE_RATE=0.0 if performance tracing is not needed
# =========================
ERROR_TRACKING_BACKEND=none
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# =========================
# NIM Assistant Integration
# NIM_ENABLED=false is safe in all environments — assistant path returns
# deterministic fallback explanation without calling the model endpoint.
#
# To activate NIM in production:
#   1. Provision an NVIDIA NIM endpoint and obtain the base URL and API key.
#   2. Set NIM_ENABLED=true.
#   3. Set NIM_BASE_URL to the endpoint base URL (no trailing slash).
#   4. Set NIM_API_KEY to the provisioned key (never commit to git).
#   5. Set NIM_MODEL to the deployed model name (e.g. meta/llama-3.1-70b-instruct).
#   6. Restart the API. The startup log will not confirm NIM — NIM is lazy-init.
#   7. Send one assistant request and check the response explanation field is
#      non-empty and does not say "deterministic fallback".
#
# NIM_TIMEOUT_SECONDS caps each individual HTTP attempt.
# NIM_MAX_RETRIES controls how many additional attempts are made on transient failures
# (429, 5xx, timeout, connection error) before NimClientError is raised.
# =========================
NIM_ENABLED=false
NIM_BASE_URL=
NIM_API_KEY=
NIM_MODEL=
NIM_TIMEOUT_SECONDS=30
NIM_MAX_RETRIES=2
NIM_LOG_IO=false

# =========================
# CORS (required before any browser-based trader UI)
# Set to a comma-separated list of allowed origins. Leave empty for pure API access.
# CONSTRAINT: Do not use * in production — enumerate origins explicitly. The localhost
# placeholder in .env.prod must be replaced with the real Decision Renderer origin
# before browser integration begins.
# =========================
CORS_ALLOW_ORIGINS=
# Production (Decision Renderer):
# CORS_ALLOW_ORIGINS=https://decision-renderer-staging.afcfta.example,https://decision-renderer.afcfta.example

# =========================
# Trusted host enforcement
# Required outside development/test/ci. Comma-separated hostnames only; no scheme.
# Example: ALLOWED_HOSTS=api.afcfta.example,staging-api.afcfta.example
# =========================
ALLOWED_HOSTS=

# =========================
# Frontend browser client
# The Vite trader UI reads its browser-facing API key from frontend/.env.
# Keep the browser env file separate from the backend .env file.
# See frontend/.env.example for the expected shape.
# =========================
