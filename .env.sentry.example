# GlitchTip environment — used by docker-compose.sentry.yml
# Copy to .env.sentry and fill in the values below.
# Do not commit .env.sentry to git.
#
# Start the stack with:
#   docker compose -f docker-compose.sentry.yml --env-file .env.sentry up -d

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-random-string

# Database password for the GlitchTip-internal PostgreSQL instance.
# This database is separate from the API database.
GLITCHTIP_DB_PASSWORD=glitchtip_dev

# The public URL where GlitchTip is reachable (used in emails and DSN display).
GLITCHTIP_DOMAIN=http://localhost:8100

# Email — consolemail:// prints to stdout (fine for local dev).
# For real email: smtp://user:password@smtp.example.com:587
DEFAULT_FROM_EMAIL=noreply@localhost
EMAIL_URL=consolemail://

# How many days to retain error events before automatic cleanup.
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90
